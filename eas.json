{
  "cli": { "version": ">=12.0.0", "appVersionSource": "remote" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": { "EXPO_PUBLIC_SUPABASE_URL": "https://auth.purama.dev" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": { "simulator": true }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "matiss.frasne@gmail.com",
        "ascAppId": "TO_FILL_AFTER_APPLE_DEV",
        "appleTeamId": "TO_FILL_AFTER_APPLE_DEV"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
